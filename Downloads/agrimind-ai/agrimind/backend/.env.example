# AgriMind AI - Environment Configuration
# Copy this file to .env and fill in your values

# AI Provider (choose one: openai, gemini, local)
AI_PROVIDER=gemini

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (alternative)
OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Model Paths
CROP_MODEL_PATH=models/crop_model.pkl
DISEASE_MODEL_PATH=models/disease_model.pt
RAG_INDEX_PATH=rag/faiss_index

# Supported Languages
SUPPORTED_LANGUAGES=en,ta,hi
DEFAULT_LANGUAGE=en
